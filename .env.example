# ============================================================
# RAG with Guardrails — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- API Security (required, no default) ---
API_KEY=your-secret-api-key-here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Database ---
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/rag_guardrails
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=rag_guardrails

# --- Embeddings ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DIM=384
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
NLI_MODEL=cross-encoder/nli-deberta-v3-small
HF_CACHE_DIR=/app/.cache/huggingface

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Guardrails ---
TOPIC_SIMILARITY_THRESHOLD=0.35
MAX_UPLOAD_SIZE_MB=50

# --- Rate limiting ---
QUERY_RATE_LIMIT=30/minute
UPLOAD_RATE_LIMIT=10/minute

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO

# --- Frontend (set in frontend/.env.local) ---
# VITE_API_URL=http://localhost:8000
